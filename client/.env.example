# Copy this file to .env and fill in your values.
# Never commit .env to git.

# URL of the backend API server.
# Local dev: leave as default (http://localhost:3001)
# Production: set to your Render backend URL, e.g. https://prompt-refina-api.onrender.com
VITE_API_URL=http://localhost:3001

# Supabase (OPTIONAL) — enables accounts + cloud sync.
# Leave both blank to run the app fully anonymously (local-only, the default).
# Get these from your Supabase project: Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anonymous refinement trial cap (OPTIONAL) — how many refinements a logged-out
# visitor may run PER DAY before being asked to sign in (resets at local
# midnight). Defaults to 5 if unset. Raise/lower to taste; set very high to
# effectively disable the gate.
VITE_ANON_REFINEMENT_LIMIT=5
