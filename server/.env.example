# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Production only — comma-separated list of allowed frontend origins
# e.g. https://your-app.vercel.app,https://your-custom-domain.com
# Leave blank for local dev (localhost:5173 and localhost:4173 are allowed by default)
ALLOWED_ORIGINS=

# Production only — set automatically by Render via RENDER_EXTERNAL_URL
# Only needed if self-hosting outside Render
APP_URL=

# Production only — path to persistent disk (set automatically via render.yaml)
DATA_DIR=

# Optional — override the default port (3001)
PORT=3001
