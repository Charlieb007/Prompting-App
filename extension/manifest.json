{
  "manifest_version": 3,
  "name": "Prompt Refina",
  "version": "0.1.0",
  "description": "Refine rough prompts into well-structured ones, without leaving your browser.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Refine a prompt",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "http://localhost:3001/*"
  ]
}
